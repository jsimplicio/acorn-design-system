# Hide everything by default
*

# But keep these essential files
!README.md
!.gitignore
!.github/
!.github/**

# Keep source token definitions (JSON files that build to tokens/)
!src/
!src/**

# Keep built tokens (CSS files)
!tokens/
!tokens/**

# Keep components (web components source)
!components/
!components/**

# Keep styles (CSS imports and utilities)
!styles/
!styles/**

# Keep utils (utility files)
!utils/
!utils/**

# Keep the examples directory
!examples/
!examples/**

# Keep package files
!package.json
!package-lock.json

# Keep the build configuration
!tokens-config.cjs
