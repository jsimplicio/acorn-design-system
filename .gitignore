# Hide everything by default
*

# But keep these essential files
!README.md
!.gitignore
!.github/
!.github/**

# Keep the complete import file
!acorn.css

# Keep the acorn-tokens directory and all its contents
!acorn-tokens/
!acorn-tokens/**

# Keep the acorn-utils directory and all its contents
!acorn-utils/
!acorn-utils/**

# Keep package.json and package-lock.json for npm compatibility (if users want to build)
!package.json
!package-lock.json

# Keep the src/ directory with split token files
!src/
!src/**

# Keep the build configuration for the acorn design system
!tokens-config.cjs

# Keep the components directory with all web components
!components/
!components/**

# Keep the demo page
!demo.html
